@startuml
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor LightCyan
    BorderColor DarkCyan
}

actor "Khách vãng lai\n(Guest)" as Guest
actor "Khách hàng\n(Customer)" as Customer
actor "Quản trị viên\n(Admin)" as Admin
actor "Cổng thanh toán" as PG

Guest <|-- Customer

rectangle "Hệ thống Website Đặt vé xem phim" {

    package "1. Identity & Access (Tài khoản)" {
        usecase "Đăng ký / Đăng nhập" as UC_Auth
        usecase "Quản lý Hồ sơ cá nhân" as UC_Profile
        usecase "Quản lý User" as UC_ManageUsers
    }

    package "2. Catalog (Danh mục Phim)" {
        usecase "Xem & Tìm kiếm Phim" as UC_ViewMovies
        usecase "Quản lý Phim" as UC_ManageMovies
        usecase "Quản lý Thể loại" as UC_ManageGenres
    }

    package "3. Infrastructure (Cơ sở vật chất)" {
        usecase "Quản lý Cụm rạp & Phòng chiếu" as UC_ManageCinemas
        usecase "Quản lý Sơ đồ ghế" as UC_ManageSeats
    }

    package "4. Food & Beverage (Dịch vụ ăn uống)" {
        usecase "Xem Menu F&B" as UC_ViewFB
        usecase "Quản lý danh mục F&B" as UC_ManageFB
    }

    package "5. Operations (Lịch chiếu & Đặt vé)" {
        usecase "Xem Lịch chiếu" as UC_ViewShowtimes
        usecase "Quản lý Lịch chiếu" as UC_ManageShowtimes
        usecase "Đặt vé trực tuyến" as UC_BookTicket
        usecase "Chọn ghế ngồi" as UC_SelectSeat
        usecase "Chọn Đồ ăn/Thức uống" as UC_SelectFB
        usecase "Thanh toán đơn hàng" as UC_Payment
        usecase "Xem Lịch sử đặt vé" as UC_ViewHistory
    }
}

' ==========================================
' RELATIONSHIPS
' ==========================================

' Guest
Guest --> UC_Auth
Guest --> UC_ViewMovies
Guest --> UC_ViewFB
Guest --> UC_ViewShowtimes

' Customer
Customer --> UC_Profile
Customer --> UC_BookTicket
Customer --> UC_ViewHistory

' Luồng Đặt vé trực tuyến (Customer)
UC_BookTicket ..> UC_Auth : <<include>>
UC_BookTicket ..> UC_SelectSeat : <<include>>
UC_BookTicket <.. UC_SelectFB : <<extend>>
UC_BookTicket ..> UC_Payment : <<include>>

' Thanh toán
UC_Payment --> PG

' Admin (Full quyền CRUD)
Admin --> UC_Auth
Admin --> UC_ManageUsers
Admin --> UC_ManageMovies
Admin --> UC_ManageGenres
Admin --> UC_ManageCinemas
Admin --> UC_ManageSeats
Admin --> UC_ManageFB
Admin --> UC_ManageShowtimes

@enduml
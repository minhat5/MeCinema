@startuml
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor LightCyan
    BorderColor DarkCyan
}

actor "Khách vãng lai" as Guest
actor "Khách hàng" as Customer
actor "Quản trị viên" as Admin
actor "Cổng thanh toán" as PaymentGateway

Guest <|-- Customer

rectangle "Hệ thống đặt vé xem phim MeCinema" {

    package "1. Tài khoản" {
        usecase "Đăng ký / Đăng nhập" as UC_Auth
        usecase "Quản lý hồ sơ cá nhân" as UC_Profile
        usecase "Quản lý người dùng" as UC_ManageUsers
    }

    package "2. Danh mục phim" {
        usecase "Xem và tìm kiếm phim" as UC_ViewMovies
        usecase "Xem lịch chiếu" as UC_ViewShowtimes
        usecase "Quản lý phim" as UC_ManageMovies
        usecase "Quản lý thể loại" as UC_ManageGenres
    }

    package "3. Cơ sở vật chất" {
        usecase "Quản lý cụm rạp" as UC_ManageCinemas
        usecase "Quản lý phòng chiếu" as UC_ManageRooms
        usecase "Quản lý ghế và sơ đồ ghế" as UC_ManageSeats
    }

    package "4. Đồ ăn và thức uống" {
        usecase "Xem menu đồ ăn và thức uống" as UC_ViewFood
        usecase "Quản lý danh mục đồ ăn và thức uống" as UC_ManageFood
    }

    package "5. Vận hành đặt vé" {
        usecase "Đặt vé trực tuyến" as UC_BookTicket
        usecase "Chọn ghế ngồi" as UC_SelectSeat
        usecase "Chọn đồ ăn và thức uống" as UC_SelectFood
        usecase "Thanh toán đơn hàng" as UC_Payment
        usecase "Theo dõi trạng thái thanh toán" as UC_PaymentStatus
        usecase "Xem lịch sử đặt vé" as UC_ViewHistory
        usecase "Hủy đặt vé" as UC_CancelBooking
        usecase "Quản lý suất chiếu" as UC_ManageShowtimes
    }
}

Guest --> UC_Auth
Guest --> UC_ViewMovies
Guest --> UC_ViewShowtimes
Guest --> UC_ViewFood

Customer --> UC_Profile
Customer --> UC_BookTicket
Customer --> UC_ViewHistory
Customer --> UC_CancelBooking

UC_BookTicket ..> UC_Auth : <<include>>
UC_BookTicket ..> UC_SelectSeat : <<include>>
UC_BookTicket <.. UC_SelectFood : <<extend>>
UC_BookTicket ..> UC_Payment : <<include>>
UC_Payment ..> UC_PaymentStatus : <<include>>

UC_Payment --> PaymentGateway

Admin --> UC_Auth
Admin --> UC_ManageUsers
Admin --> UC_ManageMovies
Admin --> UC_ManageGenres
Admin --> UC_ManageCinemas
Admin --> UC_ManageRooms
Admin --> UC_ManageSeats
Admin --> UC_ManageFood
Admin --> UC_ManageShowtimes

@enduml
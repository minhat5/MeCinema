@startuml
skinparam shadowing false
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #0F172A
}

title Activity - Chọn ghế ngồi

start
:Khách hàng vào trang đặt vé theo showtimeId;
:Hệ thống đồng thời tải thông tin suất chiếu
và trạng thái ghế đã đặt;
:Hiển thị sơ đồ ghế;
repeat
  :Người dùng chọn hoặc bỏ chọn ghế;
  if (Ghế không khả dụng?) then (Có)
    :Chặn thao tác và thông báo;
  else (Không)
    :Cập nhật danh sách ghế đã chọn;
    :Tính lại tổng tiền tạm tính;
  endif
repeat while (Tiếp tục chọn?) is (Có)

if (Đã chọn ít nhất 1 ghế?) then (Có)
  :Bấm Tiếp tục;
  :Chuyển sang bước chọn đồ ăn/xác nhận đặt vé;
else (Không)
  :Thông báo cần chọn ghế;
endif
stop
@enduml

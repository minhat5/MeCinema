@startuml
skinparam shadowing false
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #0F172A
}

title Activity - Xem lịch sử đặt vé

start
:Khách hàng truy cập trang Lịch sử vé;
if (Đã đăng nhập?) then (Có)
  :Gửi yêu cầu GET /api/bookings/me?page&size;
  :Hệ thống lấy lịch sử đặt vé theo user hiện tại;
  if (Có dữ liệu?) then (Có)
    :Hiển thị danh sách vé theo trang;
    :Cho phép chuyển trang để xem thêm;
  else (Không)
    :Hiển thị trạng thái chưa có giao dịch;
  endif
else (Không)
  :Chuyển hướng sang trang đăng nhập;
endif
stop
@enduml

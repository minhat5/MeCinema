@startuml
skinparam shadowing false
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #0F172A
}

title Activity - Quản lý người dùng

start
:Quản trị viên vào module quản lý người dùng;
if (Đúng quyền ADMIN?) then (Có)
  :Tải danh sách người dùng;
else (Không)
  :Chặn truy cập;
  stop
endif

:Áp dụng tìm kiếm, lọc vai trò, phân trang;

if (Chọn tạo người dùng?) then (Có)
  :Nhập thông tin người dùng mới;
  if (Email chưa tồn tại?) then (Có)
    :Tạo tài khoản;
    :Thông báo thành công;
  else (Không)
    :Thông báo trùng email;
  endif
elseif (Chọn cập nhật người dùng?) then (Có)
  :Sửa thông tin người dùng;
  if (Dữ liệu hợp lệ?) then (Có)
    :Lưu thay đổi;
    :Thông báo thành công;
  else (Không)
    :Thông báo không cập nhật được;
  endif
else (Xóa người dùng)
  :Xác nhận xóa;
  if (Người dùng tồn tại?) then (Có)
    if (Là tài khoản ADMIN?) then (Có)
      :Từ chối xóa tài khoản ADMIN;
    else (Không)
      :Xóa tài khoản;
      :Thông báo thành công;
    endif
  else (Không)
    :Thông báo không tìm thấy người dùng;
  endif
endif
stop
@enduml

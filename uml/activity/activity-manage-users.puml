@startuml
skinparam shadowing false
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #0F172A
}

title Activity - Quản lý user

start
:Admin vào module quản lý user;
if (Đúng quyền Admin?) then (Có)
  :Tải danh sách người dùng;
else (Không)
  :Chặn truy cập;
  stop
endif

:Áp dụng tìm kiếm / lọc vai trò / phân trang;

if (Chọn tạo user?) then (Có)
  :Nhập thông tin user mới;
  if (Email chưa tồn tại?) then (Có)
    :Tạo tài khoản;
    :Thông báo thành công;
  else (Không)
    :Thông báo trùng email;
  endif
elseif (Chọn cập nhật user?) then (Có)
  :Sửa thông tin user;
  if (User tồn tại và dữ liệu hợp lệ?) then (Có)
    :Lưu thay đổi;
    :Thông báo thành công;
  else (Không)
    :Thông báo không cập nhật được;
  endif
else (Xóa user)
  :Xác nhận xóa;
  if (User tồn tại?) then (Có)
    if (Là tài khoản Admin?) then (Có)
      :Từ chối xóa tài khoản Admin;
    else (Không)
      :Xóa tài khoản;
      :Thông báo thành công;
    endif
  else (Không)
    :Thông báo không tìm thấy user;
  endif
endif
stop
@enduml


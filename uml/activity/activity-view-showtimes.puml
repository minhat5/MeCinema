@startuml
skinparam shadowing false
skinparam activity {
  BackgroundColor #F8FAFC
  BorderColor #334155
  ArrowColor #0F172A
}

title Activity - Xem lịch chiếu

start
:Khách truy cập trang phim hoặc trang lịch chiếu;
:Chọn ngày xem, rạp chiếu hoặc phim;
:Hệ thống tải dữ liệu lịch chiếu tương ứng;
if (Có lịch chiếu phù hợp?) then (Có)
  :Hiển thị danh sách các suất chiếu kết quả;
  :Người dùng nhấn vào một suất chiếu cụ thể;
  :Chuyển sang luồng chọn ghế lấy vé;
else (Không)
  :Hiển thị thông báo không có suất chiếu;
endif
stop
@enduml


@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Quản lý suất chiếu

actor Admin as "Quản trị viên"
participant UI as "[[../../client/src/features/admin/showtimes/pages/ManageShowtimesPage.tsx ManageShowtimesPage]]"
participant Hook as "[[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts useShowtimeCRUD]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/showtime/ShowtimeController.java ShowtimeController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/impl/ShowtimeServiceImpl.java ShowtimeServiceImpl]]"
database ShowtimeRepo as "[[../../src/main/java/com/mecinema/mecinema/repo/ShowtimeRepository.java ShowtimeRepository]]"
database RoomRepo as "[[../../src/main/java/com/mecinema/mecinema/repo/RoomRepository.java RoomRepository]]"
database BookingRepo as "[[../../src/main/java/com/mecinema/mecinema/repo/BookingRepository.java BookingRepository]]"

== Tải danh sách suất chiếu ==
Admin -> UI: Mở /admin/showtimes
UI -> Hook: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts useShowtimes({page, limit, sort})]]
Hook -> API: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts getShowtimes(params)]] GET /api/showtimes?page&size&sortBy&sortDirection
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/showtime/ShowtimeController.java#L42 getAllShowtimes(...)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/ShowtimeService.java getAllShowtimes(pageable)]]
Svc -> ShowtimeRepo: [[../../src/main/java/com/mecinema/mecinema/repo/ShowtimeRepository.java findAll(pageable)]]
ShowtimeRepo --> Svc: Page<Showtime>
Svc --> Ctl: PaginatedResponse<ShowtimeDTO>
Ctl --> API: 200 ApiResponse
API --> UI: Render bảng suất chiếu

== Tạo suất chiếu ==
UI -> Hook: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts useCreateShowtime(payload)]]
Hook -> API: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts createShowtime(payload)]] POST /api/showtimes
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/showtime/ShowtimeController.java#L67 createShowtime(request)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/ShowtimeService.java createShowtime(request)]]
Svc -> ShowtimeRepo: [[../../src/main/java/com/mecinema/mecinema/repo/ShowtimeRepository.java save(showtime)]]
ShowtimeRepo --> Svc: Showtime
Svc --> Ctl: ShowtimeDTO
Ctl --> API: 201
API --> UI: Thông báo thành công

== Cập nhật/Hủy suất chiếu ==
alt Cập nhật
  UI -> Hook: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts useUpdateShowtime(id, payload)]]
  Hook -> API: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts updateShowtime(id, payload)]] PUT /api/showtimes/{id}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/showtime/ShowtimeController.java#L84 updateShowtime(id, request)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/ShowtimeService.java updateShowtime(id, request)]]
  Svc -> ShowtimeRepo: [[../../src/main/java/com/mecinema/mecinema/repo/ShowtimeRepository.java findById(id)]]
  alt Không tìm thấy suất chiếu
    ShowtimeRepo --> Svc: empty
    Svc --> Ctl: RuntimeException
    Ctl --> API: 400
    API --> UI: Báo lỗi không tìm thấy suất chiếu
  else Tìm thấy suất chiếu
    ShowtimeRepo --> Svc: Showtime
    alt request có roomId mới
      Svc -> RoomRepo: [[../../src/main/java/com/mecinema/mecinema/repo/RoomRepository.java findById(roomId)]]
      alt Không tìm thấy phòng mới
        RoomRepo --> Svc: empty
        Svc --> Ctl: RuntimeException
        Ctl --> API: 400
        API --> UI: Báo lỗi phòng không tồn tại
      else Tìm thấy phòng mới
        RoomRepo --> Svc: Room
        alt Đổi sang cơ sở khác
          Svc -> BookingRepo: [[../../src/main/java/com/mecinema/mecinema/repo/BookingRepository.java existsByShowtimeIdAndStatusIn(id, status)]]
          alt Đã có người đặt vé
            BookingRepo --> Svc: true
            Svc --> Ctl: RuntimeException
            Ctl --> API: 400
            API --> UI: Báo lỗi không thể đổi sang cơ sở khác
          else Chưa có booking PENDING/SUCCESS
            BookingRepo --> Svc: false
            Svc -> Svc: setRoom(newRoom)
          end
        else Không đổi cơ sở
          Svc -> Svc: setRoom(newRoom)
        end
      end
    else Không đổi phòng
      Svc -> Svc: giữ nguyên phòng hiện tại
    end
    alt Có đổi thời gian hoặc đổi phòng
      Svc -> Svc: validateShowtimeTime(startTime, endTime)
      Svc -> ShowtimeRepo: [[../../src/main/java/com/mecinema/mecinema/repo/ShowtimeRepository.java findConflictingShowtimes(roomId, startTime, endTime)]]
      alt Trùng lịch
        ShowtimeRepo --> Svc: danh sách conflict
        Svc --> Ctl: RuntimeException
        Ctl --> API: 400
        API --> UI: Báo lỗi trùng lịch chiếu
      else Không trùng lịch
        ShowtimeRepo --> Svc: rỗng
      end
    end
    Svc -> ShowtimeRepo: [[../../src/main/java/com/mecinema/mecinema/repo/ShowtimeRepository.java save(updatedShowtime)]]
    ShowtimeRepo --> Svc: Showtime
    Svc --> Ctl: ShowtimeDTO
    Ctl --> API: 200
    API --> UI: Thông báo cập nhật thành công
  end
else Hủy/Xóa
  UI -> Hook: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts useCancelShowtime(id)]]
  Hook -> API: [[../../client/src/features/admin/showtimes/hooks/useShowtimeCRUD.ts cancelShowtime(id)]] DELETE /api/showtimes/{id}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/showtime/ShowtimeController.java#L101 deleteShowtime(id)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/ShowtimeService.java deleteShowtime(id)]]
  Svc -> ShowtimeRepo: [[../../src/main/java/com/mecinema/mecinema/repo/ShowtimeRepository.java deleteById(id)]]
  Ctl --> API: 200
end
@enduml


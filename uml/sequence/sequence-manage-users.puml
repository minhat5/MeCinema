@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Quản lý người dùng

actor Admin
participant UI as "[[../../client/src/features/admin/users/pages/UsersPage.tsx UsersPage + UserForm]]"
participant Hook as "[[../../client/src/features/admin/users/hooks/useUsers.ts useUsers hooks]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
participant Sec as "Security + @PreAuthorize"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminUserController.java AdminUserController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/impl/UserServiceImpl.java UserServiceImpl]]"
participant RoleSvc as "[[../../src/main/java/com/mecinema/mecinema/service/RoleService.java RoleService]]"
database UserRepo as "[[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java UserRepository]]"
database RoleRepo as "[[../../src/main/java/com/mecinema/mecinema/repo/RoleRepository.java RoleRepository]]"

== Tải danh sách + tìm kiếm/lọc vai trò ==
Admin -> UI: Mở /admin/users
UI -> Hook: [[../../client/src/features/admin/users/hooks/useUsers.ts useUsers({search,role,page})]]
alt Có search
  Hook -> API: [[../../client/src/features/admin/users/hooks/useUsers.ts useUsers()]] GET /api/users/search?q&page&size
else Có lọc vai trò
  Hook -> API: [[../../client/src/features/admin/users/hooks/useUsers.ts useUsers()]] GET /api/users/role/{role}?page&size
else Mặc định
  Hook -> API: [[../../client/src/features/admin/users/hooks/useUsers.ts useUsers()]] GET /api/users?page&size
end
API -> Sec: Check ROLE_ADMIN
alt Không đủ quyền
  Sec --> API: 403
  API --> UI: Chặn truy cập
else Đủ quyền
  Sec -> Ctl: search/getByRole/getAll
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/UserService.java findByKeyword/findByRole/findAll]]
  Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findAll(spec,pageable)]]
  UserRepo --> Svc: Page<User>
  Svc --> Ctl: Page<User>
  Ctl --> API: 200
  API --> UI: Render bảng
end

== Tạo người dùng ==
Admin -> UI: Submit form tạo người dùng
UI -> Hook: [[../../client/src/features/admin/users/hooks/useUsers.ts useCreateUser(data)]]
Hook -> API: [[../../client/src/features/admin/users/hooks/useUsers.ts useCreateUser()]] POST /api/users
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminUserController.java#L45 create(AdminSaveUserRequest)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/UserService.java createUser(user)]]
Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findByEmail(email)]]
alt Email đã tồn tại
  UserRepo --> Svc: User
  Svc --> Ctl: IllegalArgumentException
  Ctl --> API: 400
  API --> UI: Thông báo trùng email
else Email hợp lệ
  UserRepo --> Svc: empty
  Svc -> RoleRepo: [[../../src/main/java/com/mecinema/mecinema/repo/RoleRepository.java findByName(role)]]
  RoleRepo --> Svc: Role
  Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java save(encodedPassword)]]
  UserRepo --> Svc: User
  Svc --> Ctl: User
  Ctl --> API: 200
  API --> UI: Thông báo thành công
end

== Cập nhật người dùng ==
Admin -> UI: Submit cập nhật người dùng
UI -> Hook: [[../../client/src/features/admin/users/hooks/useUsers.ts useUpdateUser(id,data)]]
Hook -> API: [[../../client/src/features/admin/users/hooks/useUsers.ts useUpdateUser()]] PUT /api/users/{id}
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminUserController.java#L54 update(id,user)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/UserService.java updateUser(id,user)]]
Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findById(id)]]
alt Không tìm thấy người dùng
  UserRepo --> Svc: empty
  Svc --> Ctl: EntityNotFoundException
  Ctl --> API: 404
  API --> UI: Báo không cập nhật được
else Tìm thấy
  UserRepo --> Svc: User
  opt Đổi email
    Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findByEmail(newEmail)]]
    alt Email mới đã tồn tại
      UserRepo --> Svc: User
      Svc --> Ctl: IllegalArgumentException
      Ctl --> API: 400
      API --> UI: Báo trùng email
    else Email mới hợp lệ
      UserRepo --> Svc: empty
    end
  end
  Svc -> RoleRepo: [[../../src/main/java/com/mecinema/mecinema/repo/RoleRepository.java findByName(role)]]
  RoleRepo --> Svc: Role
  Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java save(updatedUser)]]
  UserRepo --> Svc: User
  Svc --> Ctl: User
  Ctl --> API: 200
  API --> UI: Thông báo thành công
end

== Xóa người dùng ==
Admin -> UI: Xác nhận xóa
UI -> API: [[../../client/src/features/admin/users/pages/UsersPage.tsx delete user action (chưa triển khai hook riêng)]] DELETE /api/users/{id}
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminUserController.java#L74 delete(id)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/UserService.java delete(id)]]
Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findById(id)]]
alt Không tồn tại
  UserRepo --> Svc: empty
  Svc --> Ctl: EntityNotFoundException
  Ctl --> API: 404
  API --> UI: Báo không tìm thấy người dùng
else Tồn tại
  UserRepo --> Svc: User
  alt User có role ADMIN
    Svc --> Ctl: RuntimeException("Không thể xóa tài khoản Admin")
    Ctl --> API: 400 (GlobalExceptionHandler)
    API --> UI: Từ chối xóa admin
  else User thường
    Svc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java deleteById(id)]]
    UserRepo --> Svc: done
    Svc --> Ctl: done
    Ctl --> API: 200
    API --> UI: Thông báo xóa thành công
  end
end
@enduml

@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Đăng nhập, Đăng ký, Phân quyền

actor User as "Người dùng"
participant UI as "[[../../client/src/features/auth/pages/LoginPage.tsx Login/Register + ProtectedRoute]]"
participant Hook as "[[../../client/src/features/auth/hooks/useCurrentUser.ts useLogin/useRegister/useCurrentUser]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control AuthCtl as "[[../../src/main/java/com/mecinema/mecinema/controller/auth/AuthController.java AuthController]]"
participant AuthSvc as "[[../../src/main/java/com/mecinema/mecinema/service/impl/AuthServiceImpl.java AuthServiceImpl]]"
participant UserSvc as "[[../../src/main/java/com/mecinema/mecinema/service/impl/UserServiceImpl.java UserServiceImpl]]"
participant AuthMgr as "AuthenticationManager"
participant JwtSvc as "[[../../src/main/java/com/mecinema/mecinema/service/JwtService.java JwtService]]"
database UserRepo as "[[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java UserRepository]]"
database RoleRepo as "[[../../src/main/java/com/mecinema/mecinema/repo/RoleRepository.java RoleRepository]]"

== Kiểm tra phiên khi vào route bảo vệ ==
User -> UI: Truy cập /admin hoặc /member
UI -> Hook: [[../../client/src/features/auth/hooks/useCurrentUser.ts useCurrentUser()]]
Hook -> API: GET /api/user/me (Bearer token)
API -> UserSvc: [[../../src/main/java/com/mecinema/mecinema/service/impl/UserServiceImpl.java#L100 authed(authentication)]]
UserSvc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findByEmail(authentication.name)]]
UserRepo --> UserSvc: User
UserSvc --> API: 200 User
API --> Hook: User
Hook --> UI: user + role

alt Có quyền phù hợp
  UI --> User: Hiển thị trang được yêu cầu
else Không có token hoặc sai quyền
  UI --> User: Redirect /login hoặc /
end

== Đăng ký ==
User -> UI: Gửi form đăng ký
UI -> Hook: [[../../client/src/features/auth/hooks/useRegister.ts useRegister.mutate(payload)]]
Hook -> API: [[../../client/src/features/auth/services/auth.service.ts registerApi()]] POST /api/auth/register
API -> AuthCtl: [[../../src/main/java/com/mecinema/mecinema/controller/auth/AuthController.java#L27 register(RegisterReq)]]
AuthCtl -> AuthSvc: [[../../src/main/java/com/mecinema/mecinema/service/impl/AuthServiceImpl.java#L34 register(registerReq)]]
AuthSvc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java existsByEmail(email)]]
alt Email đã tồn tại
  UserRepo --> AuthSvc: true
  AuthSvc --> AuthCtl: throw RuntimeException
  AuthCtl --> API: 400
  API --> UI: Hiển thị lỗi
else Hợp lệ
  UserRepo --> AuthSvc: false
  AuthSvc -> RoleRepo: [[../../src/main/java/com/mecinema/mecinema/repo/RoleRepository.java findByName(CUSTOMER)]]
  RoleRepo --> AuthSvc: Role
  AuthSvc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java save(new User)]]
  UserRepo --> AuthSvc: User
  AuthSvc --> AuthCtl: OK
  AuthCtl --> API: 200
  Hook -> API: [[../../client/src/features/auth/services/auth.service.ts loginApi()]] POST /api/auth/login (auto login)
  API -> AuthCtl: [[../../src/main/java/com/mecinema/mecinema/controller/auth/AuthController.java#L33 login(LoginReq)]]
  AuthCtl -> AuthSvc: [[../../src/main/java/com/mecinema/mecinema/service/impl/AuthServiceImpl.java#L53 login(loginReq)]]
  AuthSvc -> AuthMgr: [[../../src/main/java/com/mecinema/mecinema/service/impl/AuthServiceImpl.java#L55 authenticate(email, password)]]
  AuthMgr --> AuthSvc: Authentication
  AuthSvc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findByEmail(email)]]
  UserRepo --> AuthSvc: User
  AuthSvc -> JwtSvc: [[../../src/main/java/com/mecinema/mecinema/service/JwtService.java generate(subject, claims)]]
  JwtSvc --> AuthSvc: token
  AuthSvc --> AuthCtl: AuthRes(token)
  AuthCtl --> API: 200 + Set-Cookie AUTH_TOKEN
  API --> Hook: success
  Hook --> UI: lưu accessToken marker + invalidate ["me"]
  UI --> User: Điều hướng về trang chính
end

== Đăng nhập ==
User -> UI: Gửi form đăng nhập
UI -> Hook: [[../../client/src/features/auth/hooks/useLogin.ts useLogin.mutate(credentials)]]
Hook -> API: [[../../client/src/features/auth/services/auth.service.ts loginApi()]] POST /api/auth/login
API -> AuthCtl: [[../../src/main/java/com/mecinema/mecinema/controller/auth/AuthController.java#L33 login(LoginReq)]]
AuthCtl -> AuthSvc: [[../../src/main/java/com/mecinema/mecinema/service/impl/AuthServiceImpl.java#L53 login(loginReq)]]
AuthSvc -> AuthMgr: [[../../src/main/java/com/mecinema/mecinema/service/impl/AuthServiceImpl.java#L55 authenticate(...)]]
alt Sai thông tin
  AuthMgr --> AuthSvc: throw exception
  AuthSvc --> AuthCtl: exception
  AuthCtl --> API: 400/401
  API --> UI: Thông báo đăng nhập thất bại
else Thành công
  AuthMgr --> AuthSvc: Authentication
  AuthSvc -> UserRepo: [[../../src/main/java/com/mecinema/mecinema/repo/UserRepository.java findByEmail(email)]]
  UserRepo --> AuthSvc: User
  AuthSvc -> JwtSvc: [[../../src/main/java/com/mecinema/mecinema/service/JwtService.java generate(...)]]
  JwtSvc --> AuthSvc: token
  AuthSvc --> AuthCtl: AuthRes(token)
  AuthCtl --> API: 200 + Set-Cookie
  API --> Hook: success
  Hook --> UI: set localStorage(accessToken/COOKIE_AUTH)
  UI -> Hook: invalidate ["me"] để nạp role
  UI --> User: Điều hướng Admin/Member theo role
end
@enduml


@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Thanh toán đơn hàng

actor Customer as "Khách hàng"
participant UI as "[[../../client/src/features/booking/pages/BookingConfirmPage.tsx BookingConfirmPage/BookingResultPage]]"
participant Hook as "[[../../client/src/features/booking/hooks/usePayment.ts usePayment]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/payment/PaymentController.java PaymentController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/PaymentService.java PaymentService]]"
participant Gateway as "[[../../src/main/java/com/mecinema/mecinema/payment/impl/SePayGatewayClient.java SePay]]"

== Khởi tạo thanh toán ==
Customer -> UI: Bấm Thanh toán
UI -> Hook: [[../../client/src/features/booking/hooks/usePayment.ts usePayment.mutate({ bookingId })]]
Hook -> API: [[../../client/src/features/booking/services/payment.service.ts createPaymentApi(bookingId, regenerate)]] POST /api/bookings/{id}/payments
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/payment/PaymentController.java#L33 initPayment(currentUser, id, request)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/PaymentService.java initPayment(userId, bookingId, request)]]
Svc -> Gateway: Tạo giao dịch và QR
Gateway --> Svc: paymentUrl + mã giao dịch
Svc --> Ctl: PaymentInitResponse
Ctl --> API: 201 Created
API --> UI: paymentUrl/QR
UI --> Customer: Hiển thị thông tin thanh toán

== Kiểm tra trạng thái thanh toán ==
loop Trong thời gian chờ thanh toán
  UI -> API: [[../../client/src/features/booking/services/payment.service.ts checkPaymentStatusApi(bookingId, paymentId)]] GET /api/bookings/{id}/payments/status
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/payment/PaymentController.java#L24 checkPaymentStatus(currentUser, id, paymentId)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/PaymentService.java checkPaymentStatusAPI(id, paymentId)]]
  Svc --> Ctl: true/false
  Ctl --> API: 200
end

alt Thanh toán thành công
  UI --> Customer: Hiển thị kết quả thành công
else Quá hạn hoặc thất bại
  UI --> Customer: Hiển thị kết quả thất bại
end

== Callback từ cổng thanh toán ==
Gateway -> API: POST /api/payments/callback
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/payment/PaymentController.java#L42 callback(authHeader, payload)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/PaymentService.java handleCallback(payload, token)]]
Svc --> Ctl: done
Ctl --> API: 200
@enduml


@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Theo dõi trạng thái thanh toán

actor User as "Khách hàng"
participant UI as "[[../../client/src/features/booking/pages/BookingResultPage.tsx BookingResultPage]]"
participant Hook as "[[../../client/src/features/booking/hooks/usePaymentStatus.ts usePaymentStatus]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/payment/PaymentController.java PaymentController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/PaymentService.java PaymentService]]"
participant Gateway as "[[../../src/main/java/com/mecinema/mecinema/payment/impl/SePayGatewayClient.java SePay]]"

== Frontend kiểm tra trạng thái ==
loop Trong thời gian chờ thanh toán
  UI -> Hook: [[../../client/src/features/booking/hooks/usePaymentStatus.ts checkPaymentStatusApi(bookingId, paymentId)]]
  Hook -> API: [[../../client/src/features/booking/services/payment.service.ts checkPaymentStatusApi(bookingId, paymentId)]] GET /api/bookings/{id}/payments/status
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/payment/PaymentController.java#L24 checkPaymentStatus(currentUser, id, paymentId)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/PaymentService.java checkPaymentStatusAPI(id, paymentId)]]
  Svc --> Ctl: true/false
  Ctl --> API: 200
  API --> Hook: Trạng thái thanh toán
  Hook --> UI: Trạng thái thanh toán
end

alt Thành công
  UI --> User: Hiển thị thanh toán thành công
else Hết hạn/Thất bại
  UI --> User: Hiển thị thanh toán thất bại
end

== Callback đồng bộ trạng thái từ cổng thanh toán ==
Gateway -> API: POST /api/payments/callback
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/payment/PaymentController.java#L42 callback(authHeader, payload)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/PaymentService.java handleCallback(payload, token)]]
Svc --> Ctl: done
Ctl --> API: 200
@enduml


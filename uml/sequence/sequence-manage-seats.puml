@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Quản lý ghế và sơ đồ ghế

actor Admin as "Quản trị viên"
participant UI as "[[../../client/src/features/admin/rooms/pages/ManageSeatsPage.tsx ManageSeatsPage]]"
participant Hook as "[[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useSeatCRUD]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminSeatController.java AdminSeatController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/SeatManagementService.java SeatManagementService]]"
database Repo as "[[../../src/main/java/com/mecinema/mecinema/repo/SeatRepository.java SeatRepository]]"

== Tải danh sách ghế và sơ đồ ==
Admin -> UI: Chọn phòng chiếu
UI -> Hook: [[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useSeatsByRoom(roomId) + useSeatMapLayout(roomId)]]
par Danh sách ghế
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useSeatsByRoom()]] GET /api/admin/seats?roomId&page&size
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminSeatController.java#L58 getSeatsByRoom(...)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/SeatManagementService.java getSeatsByRoom(roomId, pageable)]]
  Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/SeatRepository.java findByRoomId(...)]]
  Repo --> Svc: Page<Seat>
  Ctl --> API: 200
else Sơ đồ ghế
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useSeatMapLayout()]] GET /api/admin/seats/layout/{roomId}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminSeatController.java#L76 getSeatMapLayout(roomId)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/SeatManagementService.java getSeatMapLayout(roomId)]]
  Svc --> Ctl: SeatMapLayoutDto
  Ctl --> API: 200
end
API --> UI: Hiển thị danh sách ghế và sơ đồ

== Tạo/Cập nhật/Xóa ghế ==
alt Tạo một ghế
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useCreateSeat()]] POST /api/admin/seats
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminSeatController.java#L28 createSeat(dto)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/SeatManagementService.java createSeat(dto)]]
  Ctl --> API: 201
else Tạo nhiều ghế
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useBulkCreateSeats()]] POST /api/admin/seats/bulk
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminSeatController.java#L43 createSeatsInBulk(dto)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/SeatManagementService.java createSeatsInBulk(dto)]]
  Ctl --> API: 201
else Cập nhật ghế
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useUpdateSeat()]] PATCH /api/admin/seats/{seatId}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminSeatController.java#L106 updateSeat(seatId, dto)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/SeatManagementService.java updateSeat(seatId, dto)]]
  Ctl --> API: 200
else Xóa ghế
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useSeatCRUD.ts useDeleteSeat()]] DELETE /api/admin/seats/{seatId}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminSeatController.java#L123 deleteSeat(seatId)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/SeatManagementService.java deleteSeat(seatId)]]
  Ctl --> API: 200
end
@enduml


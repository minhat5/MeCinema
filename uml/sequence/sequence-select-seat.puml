@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Chọn ghế ngồi

actor User as "Khách hàng"
participant UI as "[[../../client/src/features/booking/pages/BookingPage.tsx BookingPage/SeatSelection]]"
participant Hook as "[[../../client/src/features/booking/hooks/useSeatMap.ts useSeatMap]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control ShowCtl as "[[../../src/main/java/com/mecinema/mecinema/controller/showtime/ShowtimeController.java ShowtimeController]]"
control BookCtl as "[[../../src/main/java/com/mecinema/mecinema/controller/booking/BookingController.java BookingController]]"
participant SeatSvc as "[[../../src/main/java/com/mecinema/mecinema/service/SeatAvailabilityService.java SeatAvailabilityService]]"

== Tải dữ liệu suất chiếu và trạng thái ghế ==
User -> UI: Mở trang /booking/:slug/:showtimeId
UI -> Hook: [[../../client/src/features/booking/hooks/useSeatMap.ts useSeatMap(showtimeId)]]
par Lấy thông tin suất chiếu
  Hook -> API: [[../../client/src/features/booking/services/booking.service.ts getSeatMapApi(showtimeId)]] GET /api/showtimes/{showtimeId}
  API -> ShowCtl: [[../../src/main/java/com/mecinema/mecinema/controller/showtime/ShowtimeController.java#L31 getShowtimeById(showtimeId)]]
  ShowCtl --> API: 200 ApiResponse<ShowtimeDTO>
else Lấy trạng thái ghế
  Hook -> API: [[../../client/src/features/booking/services/booking.service.ts getSeatMapApi(showtimeId)]] GET /api/bookings/showtimes/{showtimeId}/seats
  API -> BookCtl: [[../../src/main/java/com/mecinema/mecinema/controller/booking/BookingController.java#L30 getSeatAvailability(showtimeId)]]
  BookCtl -> SeatSvc: [[../../src/main/java/com/mecinema/mecinema/service/SeatAvailabilityService.java getSeatAvailability(showtimeId)]]
  SeatSvc --> BookCtl: SeatAvailabilityResponse
  BookCtl --> API: 200
end
API --> Hook: Dữ liệu suất chiếu + danh sách ghế
Hook --> UI: Render sơ đồ ghế, ghế đã đặt và giá

== Chọn/Bỏ chọn ghế ==
loop Mỗi lần người dùng click ghế
  User -> UI: Chọn hoặc bỏ chọn một ghế
  UI -> UI: Kiểm tra ghế hợp lệ và chưa bị khóa
  UI -> UI: Cập nhật selectedSeats và tổng tiền
end

User -> UI: Bấm Tiếp tục
UI -> UI: Kiểm tra có ít nhất 1 ghế
UI --> User: Chuyển sang bước chọn đồ ăn/xác nhận
@enduml

@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Quản lý cụm rạp

actor Admin as "Quản trị viên"
participant UI as "[[../../client/src/features/admin/cinemas/pages/ManageCinemasPage.tsx ManageCinemasPage]]"
participant Hook as "[[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useAdminCinemas/useCreateCinema/...]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
participant Sec as "@PreAuthorize(ADMIN)"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminCinemaController.java AdminCinemaController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/CinemaService.java CinemaService]]"
database Repo as "[[../../src/main/java/com/mecinema/mecinema/repo/CinemaRepository.java CinemaRepository]]"

== Tải danh sách cụm rạp ==
Admin -> UI: Mở /admin/cinemas
UI -> Hook: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useAdminCinemas({page, limit, search})]]
alt Có từ khóa
  Hook -> API: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useAdminCinemas()]] GET /api/cinemas/search?q&page&size
else Không có từ khóa
  Hook -> API: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useAdminCinemas()]] GET /api/cinemas?page&size
end
API -> Sec: Kiểm tra quyền ADMIN
Sec -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminCinemaController.java#L44 searchCinemas(...)/getAllCinemas(...)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/CinemaService.java search/findAll]]
Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/CinemaRepository.java findAll/findByNameContainingIgnoreCase]]
Repo --> Svc: Page<Cinema>
Svc --> Ctl: Kết quả phân trang
Ctl --> API: 200 CinemaApiResponse
API --> UI: Hiển thị bảng dữ liệu

== Tạo/Cập nhật/Xóa ==
alt Tạo cụm rạp
  UI -> Hook: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useCreateCinema(payload)]]
  Hook -> API: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useCreateCinema()]] POST /api/cinemas
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminCinemaController.java#L78 createCinema(request)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/CinemaService.java create(request)]]
  Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/CinemaRepository.java save(cinema)]]
  Repo --> Svc: Cinema
  Svc --> Ctl: Cinema
  Ctl --> API: 201
else Cập nhật cụm rạp
  UI -> Hook: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useUpdateCinema(payload)]]
  Hook -> API: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useUpdateCinema()]] PUT /api/cinemas/{id}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminCinemaController.java#L92 updateCinema(id, request)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/CinemaService.java update(id, request)]]
  Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/CinemaRepository.java save(updatedCinema)]]
  Ctl --> API: 200
else Xóa cụm rạp
  UI -> Hook: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useDeleteCinema(id)]]
  Hook -> API: [[../../client/src/features/admin/cinemas/hooks/useCinemas.ts useDeleteCinema()]] DELETE /api/cinemas/{id}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/AdminCinemaController.java#L111 deleteCinema(id)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/CinemaService.java delete(id)]]
  Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/CinemaRepository.java deleteById(id)]]
  Ctl --> API: 200
end
API --> UI: Invalidate query và tải lại danh sách
@enduml


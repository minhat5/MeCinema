@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Chọn đồ ăn và thức uống

actor User as "Khách hàng"
participant UI as "[[../../client/src/features/booking/components/FoodSelection.tsx FoodSelection]]"
participant Hook as "[[../../client/src/features/booking/hooks/useFood.ts useAvailableFoods]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/food/FoodController.java FoodController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/FoodService.java FoodService]]"
database Repo as "[[../../src/main/java/com/mecinema/mecinema/repo/FoodRepository.java FoodRepository]]"

== Tải danh sách món ==
User -> UI: Mở bước chọn đồ ăn
UI -> Hook: [[../../client/src/features/booking/hooks/useFood.ts useAvailableFoods(page, size)]]
Hook -> API: [[../../client/src/features/booking/services/food.service.ts getAvailableFoodsApi(page, size)]] GET /api/public/foods/available?page&size
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/food/FoodController.java#L32 getAvailableFoods(page, size)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/FoodService.java search("", null, true, pageable)]]
Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/FoodRepository.java findAllBySpec(...)]]
Repo --> Svc: Page<Food>
Svc --> Ctl: Page<FoodDTO>
Ctl --> API: 200
API --> Hook: Danh sách món khả dụng
Hook --> UI: Render menu

== Chọn món ==
loop Mỗi lần thay đổi số lượng món
  User -> UI: Tăng/giảm số lượng món
  UI -> UI: Cập nhật giỏ món
  UI -> UI: Tính lại tổng tiền
end

UI --> User: Chuyển sang bước xác nhận đặt vé
@enduml


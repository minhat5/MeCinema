@startuml
skinparam shadowing false
skinparam sequence {
  ArrowColor #0F172A
  LifeLineBorderColor #334155
  LifeLineBackgroundColor #F8FAFC
  ParticipantBorderColor #334155
}

title Sequence - Quản lý phòng chiếu

actor Admin as "Quản trị viên"
participant UI as "[[../../client/src/features/admin/rooms/pages/ManageRoomsPage.tsx ManageRoomsPage]]"
participant Hook as "[[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useAdminRooms/useCreateRoom/...]]"
participant API as "[[../../client/src/lib/api-client.ts apiClient]]"
control Ctl as "[[../../src/main/java/com/mecinema/mecinema/controller/admin/RoomController.java RoomController]]"
participant Svc as "[[../../src/main/java/com/mecinema/mecinema/service/RoomService.java RoomService]]"
database Repo as "[[../../src/main/java/com/mecinema/mecinema/repo/RoomRepository.java RoomRepository]]"

== Xem danh sách phòng theo cụm rạp ==
Admin -> UI: Chọn cụm rạp
UI -> Hook: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useAdminRooms({cinemaId, page, limit})]]
Hook -> API: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useAdminRooms()]] GET /api/rooms?cinemaId&page&limit
API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/RoomController.java#L44 getRoomsByCinema(cinemaId, page, limit)]]
Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/RoomService.java getRoomsByCinema(cinemaId, pageable)]]
Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/RoomRepository.java findByCinemaId(...)]]
Repo --> Svc: Page<Room>
Svc --> Ctl: Page<RoomDto>
Ctl --> API: 200 ApiResponse<Page<RoomDto>>
API --> UI: Hiển thị danh sách phòng

== Tạo/Cập nhật/Xóa phòng ==
alt Tạo phòng
  UI -> Hook: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useCreateRoom(body)]]
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useCreateRoom()]] POST /api/rooms
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/RoomController.java#L29 createRoom(dto)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/RoomService.java createRoom(dto)]]
  Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/RoomRepository.java save(room)]]
  Ctl --> API: 201
else Cập nhật phòng
  UI -> Hook: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useUpdateRoom(id, body)]]
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useUpdateRoom()]] PATCH /api/rooms/{id}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/RoomController.java#L79 updateRoom(id, dto)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/RoomService.java updateRoom(id, dto)]]
  Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/RoomRepository.java save(updatedRoom)]]
  Ctl --> API: 200
else Xóa phòng
  UI -> Hook: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useDeleteRoom(id)]]
  Hook -> API: [[../../client/src/features/admin/rooms/hooks/useRoomCRUD.ts useDeleteRoom()]] DELETE /api/rooms/{id}
  API -> Ctl: [[../../src/main/java/com/mecinema/mecinema/controller/admin/RoomController.java#L97 deleteRoom(id)]]
  Ctl -> Svc: [[../../src/main/java/com/mecinema/mecinema/service/RoomService.java deleteRoom(id)]]
  Svc -> Repo: [[../../src/main/java/com/mecinema/mecinema/repo/RoomRepository.java deleteById(id)]]
  Ctl --> API: 200
end
@enduml

